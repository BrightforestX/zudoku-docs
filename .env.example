# Copy to `.env` for local dev. Do not commit `.env`.

# PathX.ai (and other) domain builds — see package.json scripts
# ZUDOKU_PUBLIC_DOMAIN=pathx-ai

# Zuplo monetization plugin (@zuplo/zudoku-plugin-monetization)
# Deployment name from your Zuplo project (Working Copy or deployed environment).
ZUPLO_PUBLIC_DEPLOYMENT_NAME=

# Optional: override API gateway base (defaults to https://api.zuploedge.com)
# ZUPLO_GATEWAY_SERVICE_URL=https://api.zuploedge.com
